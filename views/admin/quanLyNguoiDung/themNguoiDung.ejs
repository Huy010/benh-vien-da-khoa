<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    
    <link rel="stylesheet" href="/css/admin/style.css">
    <link rel="stylesheet" href="/css/admin/sidebar.css">
    <link rel="stylesheet" href="/css/admin/quanLyNguoiDung/themNguoiDung.css">
</head>
<body style="background-color: var(--bg-light, #f4f6f9);">
    
    <div class="d-flex vh-100 overflow-hidden">
        <%- include('../sidebar') %>

        <div class="main-content flex-grow-1 p-3 p-md-4 overflow-auto">
            <div class="container card-box bg-white p-4 p-md-5 rounded shadow-sm">
                
                <div class="form-header mb-4 border-bottom pb-3">
                    <h2 class="fw-bold" style="color: #1565c0;">
                        Thêm Người Dùng Mới
                    </h2>
                    <p class="text-muted mb-0">Nhập thông tin chi tiết để tạo tài khoản mới vào hệ thống.</p>
                </div>

                <% if(msg) { %>
                    <div class="alert alert-danger d-flex align-items-center" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i> 
                        <div><%= msg %></div>
                    </div>
                <% } %>

                <form action="/admin/themNguoiDung" method="POST">
                    
                    <div class="row g-4 mb-4">
                        
                        <div class="col-lg-6">
                            <div class="p-4 border rounded bg-light h-100 shadow-sm">
                                <h3 class="section-title mb-4">Thông Tin Tài Khoản</h3>
                                
                                <div class="mb-3">
                                    <label for="tenDangNhap" class="form-label fw-semibold">Tên đăng nhập <span class="required text-danger">*</span></label>
                                    <input type="text" id="tenDangNhap" name="tenDangNhap" class="form-control" 
                                           value="<%= oldData.tenDangNhap || '' %>" required>
                                </div>

                                <div class="mb-3">
                                    <label for="matKhau" class="form-label fw-semibold">Mật khẩu <span class="required text-danger">*</span></label>
                                    <input type="password" id="matKhau" name="matKhau" class="form-control" required placeholder="Nhập mật khẩu...">
                                </div>

                                <div class="mb-4">
                                    <label for="vaiTro" class="form-label fw-semibold">Vai trò hệ thống <span class="required text-danger">*</span></label>
                                    <select id="vaiTro" name="vaiTro" class="form-select">
                                        <option value="KhachHang" <%= (oldData.vaiTro === 'KhachHang') ? 'selected' : '' %>>Khách Hàng</option>
                                        <option value="NguoiQuanLy" <%= (oldData.vaiTro === 'NguoiQuanLy') ? 'selected' : '' %>>Người Quản Lý</option>
                                    </select>
                                </div>

                                <hr class="my-4 text-muted">

                                <h3 class="section-title mb-4">Thông Tin Liên Hệ Cơ Bản</h3>

                                <div class="mb-3">
                                    <label for="hoTen" class="form-label fw-semibold">Họ và tên <span class="required text-danger">*</span></label>
                                    <input type="text" id="hoTen" name="hoTen" class="form-control" 
                                           value="<%= oldData.hoTen || '' %>" required>
                                </div>

                                <div class="mb-3">
                                    <label for="email" class="form-label fw-semibold">Email <span class="required text-danger">*</span></label>
                                    <input type="email" id="email" name="email" class="form-control" 
                                           value="<%= oldData.email || '' %>" required placeholder="example@gmail.com">
                                </div>

                                <div class="mb-3">
                                    <label for="soDienThoai" class="form-label fw-semibold">Số điện thoại <span class="required text-danger">*</span></label>
                                    <input type="text" id="soDienThoai" name="soDienThoai" class="form-control" 
                                           value="<%= oldData.soDienThoai || '' %>" required placeholder="09xxxxxxxxx">
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <div class="p-4 border rounded bg-light h-100 shadow-sm">
                                <h3 class="section-title mb-4">Thông Tin Cá Nhân & Hồ Sơ</h3>
                                
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label for="ngaySinh" class="form-label fw-semibold">Ngày sinh</label>
                                        <input type="date" id="ngaySinh" name="ngaySinh" class="form-control" 
                                               value="<%= oldData.ngaySinh || '' %>">
                                    </div>
                                    <div class="col-md-6">
                                        <label for="gioiTinh" class="form-label fw-semibold">Giới tính</label>
                                        <select id="gioiTinh" name="gioiTinh" class="form-select">
                                            <option value="">-- Chọn giới tính --</option>
                                            <option value="Nam" <%= (oldData.gioiTinh === 'Nam') ? 'selected' : '' %>>Nam</option>
                                            <option value="Nu" <%= (oldData.gioiTinh === 'Nu') ? 'selected' : '' %>>Nữ</option>
                                            <option value="Khac" <%= (oldData.gioiTinh === 'Khac') ? 'selected' : '' %>>Khác</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label for="diaChi" class="form-label fw-semibold">Địa chỉ</label>
                                    <input type="text" id="diaChi" name="diaChi" class="form-control" 
                                           value="<%= oldData.diaChi || '' %>" placeholder="Nhập địa chỉ cư trú...">
                                </div>

                                <div id="formKhachHang">
                                    <div class="mb-3">
                                        <label for="nhomMau" class="form-label fw-semibold">Nhóm máu</label>
                                        <select id="nhomMau" name="nhomMau" class="form-select">
                                            <option value="">-- Chọn nhóm máu --</option>
                                            <option value="A" <%= (oldData.nhomMau === 'A') ? 'selected' : '' %>>A</option>
                                            <option value="B" <%= (oldData.nhomMau === 'B') ? 'selected' : '' %>>B</option>
                                            <option value="AB" <%= (oldData.nhomMau === 'AB') ? 'selected' : '' %>>AB</option>
                                            <option value="O" <%= (oldData.nhomMau === 'O') ? 'selected' : '' %>>O</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label for="tienSuBenhLy" class="form-label fw-semibold">Tiền sử bệnh lý</label>
                                        <textarea id="tienSuBenhLy" name="tienSuBenhLy" class="form-control" rows="4" 
                                                  placeholder="Ghi chú tiền sử dị ứng, bệnh nền..."><%= oldData.tienSuBenhLy || '' %></textarea>
                                    </div>
                                </div>

                                <div id="formNguoiQuanLy" style="display: none;">
                                    <div class="mb-3">
                                        <label for="boPhan" class="form-label fw-semibold">Bộ phận công tác</label>
                                        <input type="text" id="boPhan" name="boPhan" class="form-control" 
                                               value="<%= oldData.boPhan || '' %>">
                                    </div>
                                </div>

                            </div>
                        </div>

                    </div> 
                    
                    <div class="form-actions mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                        <a href="/admin/quanLyNguoiDung" class="btn btn-cancel">
                            <i class="fas fa-arrow-left me-1"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-submit">
                            <i class="fas fa-save me-1"></i> Lưu Người Dùng
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const selectVaiTro = document.getElementById("vaiTro");
            const formKhachHang = document.getElementById("formKhachHang");
            const formNguoiQuanLy = document.getElementById("formNguoiQuanLy"); // Khai báo thêm form quản lý

            function toggleFields() {
                if (!selectVaiTro) return;

                if (selectVaiTro.value === "KhachHang") {
                    // Nếu là Khách hàng: Bật form khách hàng, Tắt form quản lý
                    if(formKhachHang) formKhachHang.style.display = "block";
                    if(formNguoiQuanLy) formNguoiQuanLy.style.display = "none";
                } else if (selectVaiTro.value === "NguoiQuanLy") {
                    // Nếu là Người quản lý: Tắt form khách hàng, Bật form quản lý
                    if(formKhachHang) formKhachHang.style.display = "none";
                    if(formNguoiQuanLy) formNguoiQuanLy.style.display = "block";
                }
            }

            // Kiểm tra trạng thái ngay khi tải trang
            toggleFields();

            // Lắng nghe sự kiện thay đổi vai trò
            selectVaiTro.addEventListener("change", toggleFields);
        });
    </script>
</body>
</html>