<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Sửa Người Dùng' %></title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <link rel="stylesheet" href="/css/admin/sidebar.css">
    <link rel="stylesheet" href="/css/admin/style.css">
</head>
<body>
    
    <div class="d-flex vh-100 overflow-hidden" style="background-color: #f4f6f9;"> 
        
        <%- include('../sidebar') %>

        <div class="main-content flex-grow-1 p-3 p-md-4 overflow-auto">
            
            <div class="card-box bg-white p-4 rounded shadow-sm border-0">
                
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4 pb-2 border-bottom">
                    <h2 class="mb-0 fw-bold" style="color: var(--primary-color, #2c3e50);">
                        Chỉnh Sửa Người Dùng
                    </h2>
                    
                    <a href="/admin/quanLyNguoiDung" class="btn btn-secondary text-nowrap text-decoration-none">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                    </a>
                </div>

                <div class="mb-4">
                    <p class="text-muted">Cập nhật thông tin tài khoản cho: <strong class="text-dark fs-5"><%= user.hoTen %></strong></p>
                </div>

                <% if (typeof msg !== 'undefined' && msg) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i> <%= msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <form action="/admin/quanLyNguoiDung/suaNguoiDung/<%= user.id %>" method="POST">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Tên đăng nhập <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="tenDangNhap" value="<%= user.tenDangNhap %>" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Mật khẩu mới</label>
                            <input type="password" class="form-control" name="matKhau" placeholder="Để trống nếu không muốn đổi mật khẩu">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="hoTen" value="<%= user.hoTen %>" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Vai trò <span class="text-danger">*</span></label>
                            <select class="form-select" disabled>
                                <option value="KhachHang" <%= user.vaiTro === 'KhachHang' ? 'selected' : '' %>>Khách Hàng</option>
                                <option value="NguoiQuanLy" <%= user.vaiTro === 'NguoiQuanLy' ? 'selected' : '' %>>Người Quản Lý</option>
                            </select>
                            <input type="hidden" name="vaiTro" value="<%= user.vaiTro %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Email</label>
                            <input type="email" class="form-control" name="email" value="<%= user.email %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Số điện thoại</label>
                            <input type="text" class="form-control" name="soDienThoai" value="<%= user.soDienThoai %>" pattern="[0-9]{10}" title="Vui lòng nhập số điện thoại gồm 10 chữ số">
                        </div>

                        <% if (user.vaiTro === 'KhachHang') { %>
                            <div class="col-12 mt-4">
                                <h5 class="fw-bold mb-3 border-bottom pb-2" >
                                    <i class="fas fa-notes-medical me-2"></i>Thông tin khách hàng
                                </h5>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label fw-semibold">Ngày sinh</label>
                                        <input type="date" class="form-control" name="ngaySinh" value="<%= user.ngaySinh ? user.ngaySinh : '' %>">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-semibold">Giới tính</label>
                                        <select class="form-select" name="gioiTinh">
                                            <option value="">-- Chọn giới tính --</option>
                                            <option value="Nam" <%= user.gioiTinh === 'Nam' ? 'selected' : '' %>>Nam</option>
                                            <option value="Nữ" <%= user.gioiTinh === 'Nữ' ? 'selected' : '' %>>Nữ</option>
                                            <option value="Khác" <%= user.gioiTinh === 'Khác' ? 'selected' : '' %>>Khác</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-semibold">Nhóm máu</label>
                                        <select class="form-select" name="nhomMau">
                                            <option value="">-- Chọn nhóm máu --</option>
                                            <option value="A" <%= user.nhomMau === 'A' ? 'selected' : '' %>>A</option>
                                            <option value="B" <%= user.nhomMau === 'B' ? 'selected' : '' %>>B</option>
                                            <option value="AB" <%= user.nhomMau === 'AB' ? 'selected' : '' %>>AB</option>
                                            <option value="O" <%= user.nhomMau === 'O' ? 'selected' : '' %>>O</option>
                                        </select>
                                    </div>
                                    <div class="col-md-12">
                                        <label class="form-label fw-semibold">Địa chỉ</label>
                                        <input type="text" class="form-control" name="diaChi" value="<%= user.diaChi || '' %>">
                                    </div>
                                    <div class="col-md-12">
                                        <label class="form-label fw-semibold">Tiền sử bệnh lý</label>
                                        <textarea class="form-control" name="tienSuBenhLy" rows="3" placeholder="Ghi chú các bệnh lý nền nếu có..."><%= user.tienSuBenhLy || '' %></textarea>
                                    </div>
                                </div>
                            </div>
                        <% } %>

                        <% if (user.vaiTro === 'NguoiQuanLy') { %>
                            <div class="col-12 mt-4">
                                <h5 class="fw-bold mb-3 border-bottom pb-2">
                                    <i class="fas fa-user-shield me-2"></i>Thông tin người Quản Lý
                                </h5>
                                <div class="row g-3">
                                    <div class="col-md-12">
                                        <label class="form-label fw-semibold">Bộ phận</label>
                                        <input type="text" class="form-control" name="boPhan" value="<%= user.boPhan || '' %>" placeholder="Ví dụ: Nhân sự, Chăm sóc khách hàng...">
                                    </div>
                                </div>
                            </div>
                        <% } %>

                    </div>
                    
                    <div class="mt-4 text-end border-top pt-3">
                        <button type="submit" class="btn btn-primary px-4 py-2">
                            <i class="fas fa-save me-1"></i> Cập Nhật Người Dùng
                        </button>
                    </div>
                </form>
                    
            </div> 
        </div> 
    </div> 

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>