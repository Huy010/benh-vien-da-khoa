<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản Lý Phòng Khám</title>
    
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    
    <link rel="stylesheet" href="/css/admin/sidebar.css">
    <link rel="stylesheet" href="/css/admin/style.css">
    <link rel="stylesheet" href="/css/admin/quanLyPhongKham/quanLyPhongKham.css"> 

<style nonce="<%= cspNonce %>">
/* Các lớp thay thế thuộc tính style nội tuyến để tương thích CSP. */
.csp-admin-quanlyphongkham-quanlyphongkham-ejs-10 { background-color: #f4f6f9; }
.csp-admin-quanlyphongkham-quanlyphongkham-ejs-9 { width: 5%; }
.csp-admin-quanlyphongkham-quanlyphongkham-ejs-8 { width: 10%; }
.csp-admin-quanlyphongkham-quanlyphongkham-ejs-7 { width: 15%; }
.csp-admin-quanlyphongkham-quanlyphongkham-ejs-6 { width: 25%; }
.csp-admin-quanlyphongkham-quanlyphongkham-ejs-5 { width: 20%; }
.csp-admin-quanlyphongkham-quanlyphongkham-ejs-4 { width: 10%; }
.csp-admin-quanlyphongkham-quanlyphongkham-ejs-3 { color: var(--primary-color); }
.csp-admin-quanlyphongkham-quanlyphongkham-ejs-2 { color: #999; font-style: italic; }
.csp-admin-quanlyphongkham-quanlyphongkham-ejs-1 { color: #ccc; }
</style>
</head>
<body>

    <div class="d-flex vh-100 overflow-hidden csp-admin-quanlyphongkham-quanlyphongkham-ejs-10">
        
        <%- include('../sidebar') %>
        
        <div class="main-content flex-grow-1 p-3 p-md-4 overflow-auto">
            
            <div class="card-box bg-white p-4 rounded shadow-sm border-0">
                
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4 pb-2 border-bottom">
                    <div class="card-header-title mb-0">
                        <h2 class="mb-0">Quản Lý Phòng Khám</h2>
                    </div>

                    <a href="/admin/themPhongMoi" class="btn-add text-nowrap">
                        <i class="fas fa-plus"></i> Thêm Vị Trí Mới
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="custom-table w-100">
                        <thead>
                            <tr>
                                <th class="text-center csp-admin-quanlyphongkham-quanlyphongkham-ejs-9">STT</th>
                                <th class="text-center csp-admin-quanlyphongkham-quanlyphongkham-ejs-8">TẦNG</th>
                                <th class="text-center csp-admin-quanlyphongkham-quanlyphongkham-ejs-7">SỐ PHÒNG</th>
                                <th class="csp-admin-quanlyphongkham-quanlyphongkham-ejs-6">TÊN CHUYÊN KHOA</th>
                                <th class="csp-admin-quanlyphongkham-quanlyphongkham-ejs-5">MÔ TẢ</th>
                                <th>GHI CHÚ</th>
                                <th class="text-center csp-admin-quanlyphongkham-quanlyphongkham-ejs-4">THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof data !== 'undefined' && data.length > 0) { %>
                                <% data.forEach((item, index) => { %>
                                    <tr>
                                        <td class="text-center"><%= index + 1 %></td>
                                        <td class="text-center fw-bold"><%= item.tang %></td>
                                        <td class="text-center">
                                            <span class="badge-room"><%= item.soPhong %></span>
                                        </td>                                    
                                        <td class="fw-bold csp-admin-quanlyphongkham-quanlyphongkham-ejs-3">
                                            <% if (item.tenChuyenKhoa) { %>
                                                <%= item.tenChuyenKhoa %>
                                            <% } else { %>
                                                <span class="csp-admin-quanlyphongkham-quanlyphongkham-ejs-2">-- Chưa phân công --</span>
                                            <% } %>
                                        </td>
                                        <td class="text-muted"><%= item.moTa || "" %></td>
                                        <td class="text-muted"><%= item.ghiChu %></td>                                    
                                        <td class="action-cols text-center">
                                            <div class="action-wrapper">
                                                <% if (item.id_chuyenKhoa) { %>
                                                    <a href="/admin/xoaViTri/<%= item.soPhong %>"
                                                       class="btn-icon btn-delete text-danger js-confirm-link"
                                                       data-confirm-message="Hủy phân công chuyên khoa khỏi phòng này?"
                                                       title="Hủy phân công">
                                                        <i class="fas fa-trash fa-lg"></i>
                                                    </a>
                                                <% } else { %>
                                                    <span class="csp-admin-quanlyphongkham-quanlyphongkham-ejs-1">-</span>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">Chưa có dữ liệu phòng khám.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            
        </div>
    </div>

    <script nonce="<%= cspNonce %>">
        document.querySelectorAll('.js-confirm-link').forEach(function (link) {
            link.addEventListener('click', function (event) {
                if (!window.confirm(this.dataset.confirmMessage || 'Bạn có chắc chắn?')) {
                    event.preventDefault();
                }
            });
        });
    </script>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>