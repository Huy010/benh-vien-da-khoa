<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản Lý Bác Sĩ</title>
    
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    
    <link rel="stylesheet" href="/css/admin/sidebar.css">
    <link rel="stylesheet" href="/css/admin/style.css">
    <link rel="stylesheet" href="/css/admin/quanLyBacSi/quanLyBacSi.css">
</head>
<body>
    
    <div class="d-flex vh-100 overflow-hidden" style="background-color: #f4f6f9;"> 
        
        <%- include('../sidebar') %>

        <div class="main-content flex-grow-1 p-3 p-md-4 overflow-auto">
            
            <div class="card-box bg-white p-4 rounded shadow-sm border-0">
                
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4 pb-2 border-bottom">
                    <h2 class="mb-0 fw-bold" style="color: var(--primary-color, #2c3e50);">Quản Lý Danh Sách Bác Sĩ</h2>
                    
                    <a href="/admin/themBacSi" class="btn-add text-nowrap text-decoration-none">
                        <i class="fas fa-plus"></i> Thêm Bác Sĩ Mới
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="custom-table w-100">
                        <thead>
                            <tr>
                                <th class="text-center" style="width: 5%;">STT</th>
                                <th style="width: 20%;">Họ Tên</th>
                                <th class="text-center" style="width: 15%;">Năm Tốt Nghiệp</th>
                                <th style="width: 20%;">Chuyên Khoa</th>
                                <th style="width: 25%;">Chi Tiết</th>
                                <th class="text-center" style="width: 15%;">Thao Tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% let i = 1; %>
                            <% if(typeof danhSach !== 'undefined' && danhSach.length > 0) { %>
                                <% danhSach.forEach(bacsi => { %>
                                    <tr>
                                        <td class="text-center"><%= (currentPage - 1) * 10 + (i++) %></td>
                                        <td><strong class="text-dark"><%= bacsi.hoTen %></strong></td>
                                        <td class="text-center"><%= bacsi.namTotNghiep %></td>
                                        <td class="fw-semibold" style="color: var(--primary-color);">
                                            <%= bacsi.tenChuyenKhoa ? bacsi.tenChuyenKhoa : 'Chưa phân khoa' %>
                                        </td>
                                        
                                        <td title="<%= bacsi.chiTiet %>" class="text-muted text-truncate" style="max-width: 200px;">
                                            <%= bacsi.chiTiet %>
                                        </td>
                                        
                                        <td>
                                            <div class="action-wrapper">
                                                <a href="/admin/suaBacSi/<%= bacsi.id %>?page=<%= currentPage %>" class="btn-icon btn-edit" title="Sửa">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                
                                                <a href="/admin/xoaBacSi/<%= bacsi.id %>?page=<%= currentPage %>" 
                                                onclick="return confirm('Bạn có chắc chắn muốn xóa bác sĩ <%= bacsi.hoTen %>?')" 
                                                class="btn-icon btn-delete text-danger" title="Xóa">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        <i class="fas fa-user-md mb-3" style="font-size: 48px; opacity: 0.2;"></i>
                                        <p class="mb-0 fs-5">Chưa có dữ liệu bác sĩ nào.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div> 
                <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                    <nav aria-label="Page navigation" class="mt-4">
                        <ul class="pagination justify-content-center">
                            
                            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                <a class="page-link" href="?page=<%= currentPage - 1 %>">Trước</a>
                            </li>
                            
                            <% for(let p = 1; p <= totalPages; p++) { %>
                                <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                                    <a class="page-link" href="?page=<%= p %>"><%= p %></a>
                                </li>
                            <% } %>
                            
                            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                <a class="page-link" href="?page=<%= currentPage + 1 %>">Sau</a>
                            </li>
                            
                        </ul>
                    </nav>
                <% } %>
            </div> 
        </div> 
    </div> 

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>