<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thêm Bác Sĩ Mới</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <link rel="stylesheet" href="/css/admin/sidebar.css">
    <link rel="stylesheet" href="/css/admin/style.css">
</head>
<body>
    <div class="d-flex vh-100 overflow-hidden" style="background-color: var(--bg-light, #f4f6f9);">
        <%- include('../sidebar') %>
        
        <div class="main-content flex-grow-1 p-3 p-md-4 overflow-auto d-flex justify-content-center"> 
            <div class="card-box bg-white p-4 p-md-5 rounded shadow-sm border-0 w-100" style="max-width: 800px; height: fit-content;"> 
                
                <div class="card-header-title mb-4">
                    <h2 class="mb-0">Thêm Bác Sĩ Mới</h2>
                </div>

                <form action="/admin/themBacSi" method="POST" enctype="multipart/form-data">
                    
                    <h5 class="fw-bold mt-4 mb-3" style="color: var(--primary-color);">1. Thông tin tài khoản</h5>
                    <div class="row g-3">
                        <div class="col-md-6 form-group">
                            <label class="form-label fw-semibold">Tên đăng nhập <span class="text-danger">*</span></label>
                            <input type="text" name="tenDangNhap" value="" class="form-control" required placeholder="Nhập tên đăng nhập...">
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="form-label fw-semibold">Mật khẩu <span class="text-danger">*</span></label>
                            <input type="password" name="matKhau" class="form-control" required placeholder="Nhập mật khẩu...">
                        </div>
                    </div>

                    <hr class="my-4 text-muted">

                    <h5 class="fw-bold mb-3" style="color: var(--primary-color);">2. Thông tin cá nhân</h5>
                    <div class="form-group mb-3">
                        <label class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
                        <input type="text" name="hoTen" value="" class="form-control" required placeholder="Ví dụ: Nguyễn Văn A">
                    </div>
                    
                    <div class="row g-3 mb-3">
                        <div class="col-md-6 form-group">
                            <label class="form-label fw-semibold">Email</label>
                            <input type="email" name="email" class="form-control" placeholder="example@email.com">
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="form-label fw-semibold">Số điện thoại</label>
                            <input type="text" name="soDienThoai" class="form-control" placeholder="Nhập số điện thoại...">
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label fw-semibold">Hình ảnh đại diện</label>
                        <input type="file" name="hinhAnh" class="form-control" accept="image/*">
                    </div>

                    <hr class="my-4 text-muted">

                    <h5 class="fw-bold mb-3" style="color: var(--primary-color);">3. Thông tin chuyên môn</h5>
                    <div class="row g-3 mb-3">
                        <div class="col-md-4 form-group">
                            <label class="form-label fw-semibold">Trình độ</label>
                            <input type="text" name="trinhDo" class="form-control" placeholder="Ví dụ: ThS, TS, BS.CKI...">
                        </div>
                        <div class="col-md-4 form-group">
                            <label class="form-label fw-semibold">Năm tốt nghiệp</label>
                            <input type="number" name="namTotNghiep" class="form-control" placeholder="Ví dụ: 2015">
                        </div>
                        <div class="col-md-4 form-group">
                            <label class="form-label fw-semibold">Chuyên khoa</label>
                            <select name="id_chuyenKhoa" class="form-select shadow-none"> 
                                <option value="" disabled selected>-- Chọn chuyên khoa --</option>
                                <% dsKhoa.forEach(function(khoa) { %>
                                    <option value="<%= khoa.id_chuyenKhoa %>"> <%= khoa.tenChuyenKhoa %> </option>
                                <% }); %>
                            </select>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-semibold">Chi tiết / Giới thiệu</label>
                        <textarea name="chiTiet" class="form-control" rows="4" placeholder="Nhập thông tin giới thiệu về bác sĩ..."></textarea>
                    </div>

                    <hr class="my-4 text-muted">

                    <div class="d-flex gap-2 justify-content-start align-items-center mt-4">
                        <button type="submit" class="btn btn-add px-4 py-2">
                            Lưu Bác Sĩ
                        </button>
                        <a href="/admin/quanLyBacSi" class="btn btn-light px-4 py-2 border fw-semibold text-muted" style="background-color: #e9ecef;">
                            Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <% if (typeof msg !== 'undefined' && msg) { %>
        <script nonce="<%= cspNonce %>">
            document.addEventListener('DOMContentLoaded', function() {
                Swal.fire({ icon: 'error', title: 'Thông báo', text: '<%= msg %>', confirmButtonText: 'Đã hiểu', confirmButtonColor: '#1565C0' });
            });
        </script>
    <% } %>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>