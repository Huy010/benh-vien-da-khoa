<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trang Chủ</title>
    <link rel="stylesheet" href="/css/khachHang/home.css" />
    <link
      rel="stylesheet"
      href="/vendor/fontawesome/css/all.min.css"
    />
    <link
      href="/vendor/bootstrap/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script
      src="/vendor/bootstrap/js/bootstrap.bundle.min.js"
    ></script>
  </head>
  <body>
    <main class="main">
      <!-- ===== IMPORT HEADER TRANG CHỦ ===== -->
      <%- include('./header') %>
      <div class="content">
        <section class="heading">
          <div class="heading__group">
            <div class="heading__backgroud">
              <img
                src="/images/khachHang/hospital.jpg"
                alt=""
                class="heading__img"
              />
            </div>
            <div class="heading__text">
              <div class="row heading__tittle">
                <h1 class="col">Bệnh Viện Đa Khoa Thành Phố Cần Thơ</h1>
                <h3>Sức khỏe của bạn là ưu tiên hàng đầu</h3>
                <a href="/datLichHen" class="heading__link col-auto">
                  <span>Đặt lịch ngay</span>
                  <i class="fa-regular fa-circle-right circle-right"></i>
                </a>
              </div>
              <div class="heading__logo">
                <span>
                  <img src="/images/khachHang/boYTe.svg" alt="" />
                </span>
                <span>
                  <img src="/images/khachHang/baoHiemYTe.svg" alt="" />
                </span>
                <span>
                  <img src="/images/khachHang/iso.png" alt="" />
                </span>
              </div>
            </div>
          </div>
        </section>
        <section class="content__intro">
          <div class="row">
            <div class="col-12 col-md-6 intro__img mb-4 mb-md-0">
              <img src="/images/khachHang/daKhoa.jpg" alt="Bệnh viện đa khoa" />
            </div>
            <div class="col-12 col-md-6 intro__text">
              <h3>Thông tin chung</h3>
              <p>
                Bệnh viện Đa khoa thành phố Cần Thơ là BV hạng I, cấp chuyên sâu
                quy mô 830 giường với đội ngũ nhân viên hơn 900 người. Bệnh viện
                có 36 khoa, phòng. Trong đó: 9 phòng chức năng, 06 khoa cận lâm
                sàng và 21 khoa lâm sàng.
              </p>
              <a href="/thongTin">Chi tiết</a>
            </div>
          </div>
        </section>
        <%- include('./footer') %>
      </div>
    </main>
    <script>
      const header = document.querySelector(".header");

      function handleScroll() {
        if (window.scrollY > 50) {
          header.classList.add("header--scrolled");
        } else {
          header.classList.remove("header--scrolled");
        }
      }
      window.addEventListener("scroll", handleScroll);

      window.addEventListener("load", () => {
        window.scrollTo(0, 0);
        handleScroll();
      });
    </script>
  </body>
</html>
