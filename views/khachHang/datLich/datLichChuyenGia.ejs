<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chọn Chuyên Gia</title>

    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    <link href="/vendor/sweetalert2/sweetalert2.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/khachHang/home.css">

    <style>
        body {
            background-color: #f4f6f9;
        }

        .wrapper-page {
            margin-top: 100px;
            margin-bottom: 60px;
            min-height: 60vh;
        }

        .content-container {
            background-color: #ffffff;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        .specialty-btn {
            border-radius: 50px;
            padding: 10px 25px;
            font-weight: 600;
            margin: 6px;
            transition: all 0.3s ease;
            border-width: 2px;
        }

        .specialty-btn:hover,
        .specialty-btn.active {
            background-color: #0d6efd;
            color: white;
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.3);
            border-color: #0d6efd;
            transform: translateY(-2px);
        }

        .doctor-card {
            border: 1px solid #edf2f7;
            border-radius: 15px;
            overflow: hidden;
            transition: box-shadow 0.3s ease;
            background-color: #ffffff;
        }

        .doctor-card:hover {
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
        }

        .doctor-img {
            height: 250px;
            object-fit: cover;
            width: 100%;
            border-bottom: 3px solid #0d6efd;
        }

        .doctor-price {
            font-size: 1.2rem;
            color: #dc3545;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <%- include('../header') %>

        <div class="container wrapper-page">
            <div class="content-container p-4 p-md-5">

                <div class="text-center mb-5">
                    <h2 class="fw-bold text-primary text-uppercase">Đội Ngũ Chuyên Gia Nổi Bật</h2>
                    <p class="text-muted">
                        Vui lòng chọn chuyên khoa để xem danh sách các bác sĩ chuyên gia của chúng tôi
                    </p>
                </div>

                <div class="d-flex flex-wrap justify-content-center mb-5 pb-3 border-bottom" id="specialty-container">
                    <% if (typeof chuyenKhoa !=='undefined' && chuyenKhoa.length> 0) { %>
                        <% chuyenKhoa.forEach(ck=> { %>
                            <button class="btn btn-outline-primary specialty-btn" data-id="<%= ck.id_chuyenKhoa %>"
                                data-name="<%= ck.tenChuyenKhoa %>">
                                <%= ck.tenChuyenKhoa %>
                            </button>
                            <% }) %>
                                <% } else { %>
                                    <div class="alert alert-warning">
                                        Chưa tải được danh sách chuyên khoa từ máy chủ!
                                    </div>
                                    <% } %>
                </div>

                <div class="row" id="doctor-list-container">
                    <div class="col-12 text-center text-muted py-4">
                        <i class="fa-solid fa-user-doctor fa-4x mb-3 opacity-25"></i>
                        <h5 class="fw-normal">Đang tải danh sách bác sĩ...</h5>
                    </div>
                </div>

            </div>
        </div>

        <div class="modal fade" id="doctorDetailModal" tabindex="-1" aria-labelledby="doctorDetailModalLabel"
            aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg">
                    <div class="modal-header bg-primary text-white border-0">
                        <h5 class="modal-title fw-bold" id="doctorDetailModalLabel">
                            <i class="fa-solid fa-stethoscope me-2"></i>Thông tin Bác sĩ
                        </h5>

                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                    </div>

                    <div class="modal-body text-center p-4" id="modal-body-content">
                    </div>

                    <div class="modal-footer justify-content-center border-0 bg-light">
                        <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
                            Đóng
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
        <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>

        <script nonce="<%= cspNonce %>">
            document.addEventListener('DOMContentLoaded', () => {
                const specialtyBtns = document.querySelectorAll('.specialty-btn');
                const doctorContainer = document.getElementById('doctor-list-container');
                const doctorDetailModal = new bootstrap.Modal(document.getElementById('doctorDetailModal'));

                async function loadDoctorsBySpecialty(button) {
                    if (!button) {
                        doctorContainer.innerHTML = `
                        <div class="col-12 text-center text-muted py-5">
                            <i class="fa-solid fa-user-doctor fa-4x mb-3 opacity-25"></i>
                            <h5 class="fw-normal">Hiện chưa có chuyên khoa để hiển thị</h5>
                        </div>
                    `;
                        return;
                    }

                    specialtyBtns.forEach(b => b.classList.remove('active'));
                    button.classList.add('active');

                    const chuyenKhoaId = button.getAttribute('data-id');

                    doctorContainer.innerHTML = `
                    <div class="col-12 text-center py-5">
                        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
                        <h5 class="mt-3 text-muted">Đang tìm kiếm bác sĩ...</h5>
                    </div>
                `;

                    try {
                        const response = await fetch(`/api/bacsi?id_chuyenKhoa=${encodeURIComponent(chuyenKhoaId)}`);
                        const dataResponse = await response.json();

                        doctorContainer.innerHTML = '';

                        if (dataResponse.success && dataResponse.data && dataResponse.data.length > 0) {
                            dataResponse.data.forEach(bs => {
                                const tenBs = bs.hoTen || 'Đang cập nhật';
                                const idBs = bs.id_bacSi;
                                const chiTiet = bs.chiTiet || 'Chuyên gia giỏi và tận tâm với bệnh nhân.';
                                const trinhDo = bs.trinhDo || 'Bác sĩ chuyên khoa';
                                const namKinhNghiem = bs.namKinhNghiem || 0;
                                const hinhAnh = '/BacSi/nam.webp';

                                const doctorDataString = encodeURIComponent(JSON.stringify({
                                    id: idBs,
                                    ten: tenBs,
                                    anh: hinhAnh,
                                    chiTiet: chiTiet,
                                    trinhDo: trinhDo,
                                    namKinhNghiem: namKinhNghiem
                                }));

                                const col = document.createElement('div');
                                col.className = 'col-md-6 col-lg-4 mb-4';

                                col.innerHTML = `
                                <div class="card doctor-card h-100 shadow-sm">
                                    <img 
                                        src="${hinhAnh}" 
                                        class="card-img-top doctor-img" 
                                        alt="Bác sĩ ${tenBs}"
                                    >

                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title text-primary fw-bold mb-1">BS. ${tenBs}</h5>

                                        <p class="text-muted small mb-3 fst-italic">
                                            ${trinhDo}
                                        </p>

                                        <p class="card-text mb-4">
                                            <i class="fa-solid fa-money-bill-wave text-muted me-2 w-15px"></i>
                                            <strong>Phí khám:</strong> 
                                            <span class="doctor-price">200.000 VNĐ</span>
                                        </p>
                                        
                                        <div class="mt-auto d-grid gap-2">
                                            <button class="btn btn-outline-info btn-chi-tiet" data-info="${doctorDataString}">
                                                <i class="fa-solid fa-circle-info me-1"></i>Xem chi tiết
                                            </button>

                                            <button class="btn btn-primary fw-bold btn-chon-bs" data-id="${idBs}" data-name="${tenBs}">
                                                <i class="fa-solid fa-calendar-check me-1"></i>Đặt lịch
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            `;

                                doctorContainer.appendChild(col);
                            });

                            attachCardEvents();

                        } else {
                            doctorContainer.innerHTML = `
                            <div class="col-12 text-center text-muted py-5">
                                <i class="fa-solid fa-user-doctor-message fa-4x mb-3 text-warning opacity-75"></i>
                                <h5>Hiện chưa có chuyên gia nào thuộc chuyên khoa này!</h5>
                                <p>Vui lòng chọn chuyên khoa khác.</p>
                            </div>
                        `;
                        }

                    } catch (error) {
                        console.error("Lỗi fetch bác sĩ:", error);

                        doctorContainer.innerHTML = `
                        <div class="col-12 text-center text-danger py-5">
                            <i class="fa-solid fa-triangle-exclamation fa-4x mb-3 opacity-75"></i>
                            <h5>Đã xảy ra lỗi khi tải dữ liệu từ hệ thống!</h5>
                            <p>Vui lòng thử lại sau ít phút hoặc kiểm tra lại kết nối mạng.</p>
                        </div>
                    `;
                    }
                }

                specialtyBtns.forEach(btn => {
                    btn.addEventListener('click', function () {
                        loadDoctorsBySpecialty(this);
                    });
                });

                function attachCardEvents() {
                    document.querySelectorAll('.btn-chi-tiet').forEach(btn => {
                        btn.addEventListener('click', function () {
                            const data = JSON.parse(decodeURIComponent(this.getAttribute('data-info')));
                            const modalBody = document.getElementById('modal-body-content');

                            modalBody.innerHTML = `
                            <img 
                                src="${data.anh}" 
                                class="rounded-circle mb-3 border border-4 border-primary shadow-sm" 
                                style="width: 160px; height: 160px; object-fit: cover;"
                            >

                            <h4 class="text-primary fw-bold mb-1">BS. ${data.ten}</h4>

                            <p class="text-muted fw-semibold mb-2">
                                ${data.trinhDo}
                            </p>

                            <hr style="width: 60px; margin: 15px auto; border-top: 3px solid #0d6efd; opacity: 1;">

                            <div class="text-start px-md-3 mt-4">
                                <div class="mb-3">
                                    <h6 class="fw-bold text-dark">
                                        <i class="fa-solid fa-graduation-cap text-success me-2"></i>Kinh nghiệm:
                                    </h6>

                                    <p class="ms-4 mb-0 text-muted">
                                        ${data.namKinhNghiem} năm
                                    </p>
                                </div>

                                <div class="mb-3">
                                    <h6 class="fw-bold text-dark">
                                        <i class="fa-solid fa-stethoscope text-info me-2"></i>Giới thiệu chuyên môn:
                                    </h6>

                                    <p class="ms-4 mb-0 text-muted">
                                        ${data.chiTiet}
                                    </p>
                                </div>
                            </div>
                        `;

                            doctorDetailModal.show();
                        });
                    });

                    document.querySelectorAll('.btn-chon-bs').forEach(btn => {
                        btn.addEventListener('click', function () {
                            const id = this.getAttribute('data-id');
                            window.location.href = `/datLichChuyenGia/chonThoiGian?bacSiId=${encodeURIComponent(id)}`;
                        });
                    });
                }

                const defaultSpecialtyBtn = Array.from(specialtyBtns).find(btn => {
                    const name = btn.getAttribute('data-name') || btn.textContent || '';

                    return name
                        .trim()
                        .toLowerCase()
                        .normalize('NFD')
                        .replace(/[\u0300-\u036f]/g, '')
                        .includes('khoa noi');
                });

                if (defaultSpecialtyBtn) {
                    loadDoctorsBySpecialty(defaultSpecialtyBtn);
                } else if (specialtyBtns.length > 0) {
                    loadDoctorsBySpecialty(specialtyBtns[0]);
                }
            });
        </script>
    <%- include('../footer') %>
</body>

</html>