<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lịch sử đăng ký khám bệnh</title>
    
    <link rel="stylesheet" href="/css/khachHang/home.css" />
    <link rel="stylesheet" href="/css/khachHang/lichSuDatLich.css" />
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css"/>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet"/>
    
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/axios/axios.min.js"></script>
  </head>
  <body>
    <main class="main">
      <%- include('../header') %>

      <div class="content history-container">
        <div class="container">
          <div class="d-flex align-items-center mb-4">
            <h2 class="text-primary fw-bold mb-0">
              <i class="fa-solid fa-clock-rotate-left me-2"></i> Lịch sử đặt lịch khám
            </h2>
          </div>

          <div class="card card-history">
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                  <thead class="table-primary">
                    <tr>
                      <th class="py-3 px-4">STT</th>
                      <th class="py-3">Chuyên khoa</th>
                      <th class="py-3">Ngày khám</th>
                      <th class="py-3">Giờ hẹn</th>
                      <th class="py-3">Trạng thái</th>
                      <th class="py-3 text-center">Thao tác</th> 
                    </tr>
                  </thead>
                  <tbody>
                    <% if (typeof lichSu !== 'undefined' && lichSu.length > 0) { %>
                      <% lichSu.forEach((item, index) => { %>
                        <tr>
                          <td class="px-4 fw-bold text-muted">
                            <%= (typeof pagination !== 'undefined') ? ((pagination.currentPage - 1) * 10 + index + 1) : (index + 1) %>
                          </td>
                          <td class="fw-bold text-dark"><%= item.tenChuyenKhoa %></td>
                          <td><%= item.ngay %></td>
                          <td><span class="badge bg-light text-dark border"><i class="fa-regular fa-clock me-1"></i><%= item.gioHen %></span></td>
                          
                          <td>
                            <% if (item.trangThai === 'Huy') { %>
                              <span class="badge bg-dark">
                                <i class="bi bi-x-circle"></i> Đã hủy
                              </span>
                            <% } else if (item.trangThai === 'HoanThanh') { %>
                              <span class="badge bg-primary">
                                <i class="bi bi-person-check"></i> Đã khám xong
                              </span>
                            <% } else if (item.trangThai === 'DiTre' || item.trangThai === 'DenTre') { %> 
                              <span class="badge bg-danger">
                                <i class="bi bi-exclamation-circle"></i> Đi trễ
                              </span>
                            <% } else if (item.trangThaiThanhToan === 'ChuaThanhToan') { %>
                              <span class="badge bg-warning text-dark">
                                <i class="bi bi-clock-history"></i> Chờ thanh toán
                              </span>
                            <% } else if (item.trangThaiThanhToan === 'DaThanhToan') { %>
                              <span class="badge bg-success">
                                <i class="bi bi-check-circle"></i> Đã thanh toán
                              </span>
                            <% } else if (item.trangThaiThanhToan === 'DaHoanTien') { %> 
                              <span class="badge bg-secondary">
                                <i class="bi bi-arrow-return-left"></i> Đã hoàn tiền
                              </span>
                            <% } %>
                          </td>

                          <td class="text-center">
                            <div class="d-flex justify-content-center gap-2 align-items-center">
                              
                              <% if (item.trangThai === 'HoanThanh') { %>
                                <button type="button"
                                        class="btn btn-sm btn-info text-white js-xem-chi-tiet"
                                        data-id-lich-hen="<%= item.id_lichHen %>"
                                        data-khoa="<%= encodeURIComponent(item.tenChuyenKhoa || '') %>"
                                        data-ngay="<%= encodeURIComponent(item.ngay || '') %>"
                                        data-gio="<%= encodeURIComponent(item.gioHen || '') %>"
                                        data-bac-si="<%= encodeURIComponent(item.tenBacSi || 'Chưa cập nhật') %>"
                                        data-ghi-chu="<%= encodeURIComponent(item.ghiChu || 'Không có ghi chú') %>">
                                  <i class="fa-solid fa-eye me-1"></i> Xem chi tiết
                                </button>
                              
                              <% } else if (item.trangThai !== 'Huy' && item.trangThaiThanhToan === 'ChuaThanhToan') { %>
                                <button type="button"
                                        class="btn btn-sm btn-primary btn-thanh-toan js-thanh-toan-lai"
                                        data-id-lich-hen="<%= item.id_lichHen %>"
                                        data-don-gia="<%= item.donGia %>"
                                        data-id-chuyen-khoa="<%= item.id_chuyenKhoa %>">
                                  <i class="bi bi-credit-card"></i> Thanh toán
                                </button>

                                <% if (item.coTheHuy) { %>
                                  <button type="button" class="btn btn-sm btn-outline-danger js-huy-lich" data-id-lich-hen="<%= item.id_lichHen %>">
                                    <i class="bi bi-trash"></i> Hủy lịch
                                  </button>
                                <% } %>

                              <% } else if (item.trangThai !== 'Huy' && item.trangThaiThanhToan === 'DaThanhToan') { %>
                                <% if (item.coTheXemVe) { %>
                                  <a href="/thongTinLichKham?id=<%= item.id_lichHen %>" class="btn btn-sm btn-success text-white">
                                    Xem vé
                                  </a>
                                <% } %>

                                <% if (item.coTheHuy) { %>
                                  <button type="button" class="btn btn-sm btn-outline-danger js-huy-lich" data-id-lich-hen="<%= item.id_lichHen %>">
                                    <i class="bi bi-trash"></i> Hủy lịch
                                  </button>
                                <% } %>
                              <% } %>
                              
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr>
                        <td colspan="6" class="text-center py-5">
                          <img src="/images/khachHang/empty-calendar.svg" alt="Trống" width="120" class="mb-3 opacity-50 js-hide-on-error">
                          <h5 class="text-muted">Bạn chưa có lịch hẹn nào</h5>
                          <a href="/datLichHen" class="btn btn-outline-primary mt-2">Đặt lịch ngay</a>
                        </td>
                      </tr>
                    <% } %> 
                  </tbody>
                </table>
              </div>

              <% if (typeof pagination !== 'undefined' && pagination.totalPages > 1) { %>
                <div class="d-flex justify-content-center mt-4 mb-3">
                  <nav aria-label="Page navigation">
                    <ul class="pagination">
                      
                      <li class="page-item <%= pagination.currentPage == 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="?page=<%= pagination.currentPage - 1 %>">Trước</a>
                      </li>

                      <% for(let i = 1; i <= pagination.totalPages; i++) { %>
                        <li class="page-item <%= pagination.currentPage == i ? 'active' : '' %>">
                          <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                        </li>
                      <% } %>

                      <li class="page-item <%= pagination.currentPage == pagination.totalPages ? 'disabled' : '' %>">
                        <a class="page-link" href="?page=<%= pagination.currentPage + 1 %>">Tiếp</a>
                      </li>
                      
                    </ul>
                  </nav>
                </div>
              <% } %>
              </div>
          </div>

        </div>
      </div>

      <div class="modal fade" id="modalChiTietKham" tabindex="-1" aria-labelledby="modalChiTietKhamLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content border-0 shadow-lg">
            
            <div class="modal-header bg-primary text-white">
              <h5 class="modal-title fw-bold" id="modalChiTietKhamLabel">
                <i class="fa-solid fa-notes-medical me-2"></i> Chi tiết khám bệnh
              </h5>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-4">
              <div class="card bg-light border-0 mb-3">
                <div class="card-body">
                  <div class="row mb-2">
                    <div class="col-5 text-muted fw-bold">Mã lịch hẹn:</div>
                    <div class="col-7 text-primary fw-bold" id="detail-maLH"></div>
                  </div>
                  <div class="row mb-2">
                    <div class="col-5 text-muted fw-bold">Chuyên khoa:</div>
                    <div class="col-7 fw-bold" id="detail-khoa"></div>
                  </div>
                  <div class="row mb-2">
                    <div class="col-5 text-muted fw-bold">Thời gian:</div>
                    <div class="col-7" id="detail-thoiGian"></div>
                  </div>
                  <div class="row">
                    <div class="col-5 text-muted fw-bold">Bác sĩ khám:</div>
                    <div class="col-7" id="detail-bacSi"></div>
                  </div>
                </div>
              </div>
              
              <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">
                <i class="fa-solid fa-stethoscope text-primary me-2"></i> Kết luận / Ghi chú của Bác sĩ
              </h6>
              <div class="p-3 bg-white border rounded shadow-sm" style="min-height: 100px;">
                <p class="mb-0 text-dark" id="detail-ghiChu"></p>
              </div>
            </div>
            
            <div class="modal-footer border-0">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
          </div>
        </div>
      </div>
      <%- include('../footer') %>
    </main>
    <script nonce="<%= cspNonce %>">
      function decodeData(value) {
        try {
          return decodeURIComponent(value || '');
        } catch (error) {
          return value || '';
        }
      }

      document.querySelectorAll('.js-xem-chi-tiet').forEach(function (button) {
        button.addEventListener('click', function () {
          xemChiTiet(
            this.dataset.idLichHen || '',
            decodeData(this.dataset.khoa),
            decodeData(this.dataset.ngay),
            decodeData(this.dataset.gio),
            decodeData(this.dataset.bacSi),
            decodeData(this.dataset.ghiChu)
          );
        });
      });

      document.querySelectorAll('.js-thanh-toan-lai').forEach(function (button) {
        button.addEventListener('click', function () {
          thanhToanLai(
            this.dataset.idLichHen || '',
            this.dataset.donGia || '',
            this.dataset.idChuyenKhoa || ''
          );
        });
      });

      document.querySelectorAll('.js-huy-lich').forEach(function (button) {
        button.addEventListener('click', function () {
          huyLich(this.dataset.idLichHen || '');
        });
      });

      document.querySelectorAll('.js-hide-on-error').forEach(function (image) {
        image.addEventListener('error', function () {
          this.style.display = 'none';
        });
      });

      // Hàm xử lý khi bấm nút Thanh toán
      async function thanhToanLai(id_lichHen, donGia, id_chuyenKhoa) {
        try {
          const res = await axios.post('/thanhToanLai', {
            id_lichHen, donGia, id_chuyenKhoa
          });
          
          if (res.data.success) {
            window.location.href = res.data.payUrl; // Chuyển sang web ZaloPay
          } else {
            Swal.fire({
              icon: 'warning',
              title: 'Cảnh báo',
              text: res.data.msg
            });
          }
        } catch (error) {
          Swal.fire({
            icon: 'error',
            title: 'Lỗi',
            text: 'Lỗi hệ thống khi khởi tạo thanh toán.'
          });
        }
      }

      // Hàm xử lý khi bấm nút Hủy
      async function huyLich(id_lichHen) {
        const result = await Swal.fire({
          title: 'Bạn có chắc chắn?',
          text: "Bạn có chắc chắn muốn hủy lịch khám này không? Hành động này không thể hoàn tác.",
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#d33',
          cancelButtonColor: '#3085d6',
          confirmButtonText: 'Có',
          cancelButtonText: 'Không'
        });

        if (result.isConfirmed) {
          try {
            const res = await axios.post('/huyLich', { id_lichHen });
            
            if (res.data.success) {
              await Swal.fire({
                icon: 'success',
                title: 'Thành công!',
                text: 'Đã hủy lịch hẹn thành công!',
                confirmButtonColor: '#28a745'
              });
              window.location.reload(); // Load lại trang để cập nhật bảng
            } else {
              Swal.fire({
                icon: 'error',
                title: 'Không thể hủy',
                text: res.data.msg
              });
            }
          } catch (error) {
            Swal.fire({
              icon: 'error',
              title: 'Lỗi',
              text: 'Lỗi hệ thống khi hủy lịch.'
            });
          }
        }
      }

      // Hàm hiển thị Modal xem chi tiết khám bệnh
      function xemChiTiet(maLH, khoa, ngay, gio, bacSi, ghiChu) {
          // Gán dữ liệu vào các thẻ HTML tương ứng
          document.getElementById('detail-maLH').innerText = 'LH-' + maLH;
          document.getElementById('detail-khoa').innerText = khoa;
          document.getElementById('detail-thoiGian').innerText = gio + ' - ' + ngay;
          document.getElementById('detail-bacSi').innerText = bacSi;
          document.getElementById('detail-ghiChu').innerText = ghiChu;

          // Kích hoạt hiển thị Bootstrap Modal
          const modal = new bootstrap.Modal(document.getElementById('modalChiTietKham'));
          modal.show();
      }
    </script>
  </body>
</html>