<!DOCTYPE html>

<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Đăng nhập</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Bootstrap + FontAwesome -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- CSS -->
    <link rel="stylesheet" href="/css/admin/login.css">
    <link rel="stylesheet" href="/css/khachHang/login.css">
    <link rel="stylesheet" href="/css/khachHang/home.css">

    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


</head>

<body class="bg-gradient-primary">

    <!-- HEADER -->

    <%- include('../header') %>

        <div class="container d-flex justify-content-center align-items-center" style="min-height: 90vh;">

            <div class="card login-container border-0 shadow-lg">
                <div class="card-body p-4 p-md-5">

                    <h2 class="text-center text-dark mb-4 fw-bold">Đăng nhập</h2>

                    <form action="/login" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="mb-3">
                            <label class="form-label text-secondary fw-medium">Tên đăng nhập</label>
                            <input type="text" name="username" class="form-control form-control-brand px-3 py-2"
                                placeholder="Nhập tên đăng nhập..." required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-secondary fw-medium">Mật khẩu</label>
                            <input type="password" name="password" class="form-control form-control-brand px-3 py-2"
                                placeholder="Nhập mật khẩu..." required>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <a href="/khachHangTaoTaiKhoan" class="text-decoration-none">
                                Tạo tài khoản
                            </a>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fa-solid fa-right-to-bracket"></i> Đăng nhập
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>

        <script>
            const serverMessage = JSON.parse('<%- JSON.stringify(typeof msg !== "undefined" ? msg : "") %>');
            const messageType = JSON.parse('<%- JSON.stringify(typeof type !== "undefined" ? type : "") %>');

            if (serverMessage.trim() !== "") {

                const isError = messageType === "error";

                Swal.fire({
                    icon: isError ? 'error' : 'success',
                    title: isError ? 'Đăng nhập thất bại' : 'Thành công',
                    text: serverMessage,
                    confirmButtonColor: '#667eea',
                    confirmButtonText: 'OK'
                });
            }
        </script>

</body>

</html>