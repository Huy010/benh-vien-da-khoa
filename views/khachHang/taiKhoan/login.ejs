<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Đăng nhập</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <link rel="stylesheet" href="/css/admin/login.css">

    <link rel="stylesheet" href="/css/khachHang/login.css">

    <link rel="stylesheet" href="/css/khachHang/home.css">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gradient-primary">

    <%- include('../header') %>

        <div class="container d-flex justify-content-center align-items-center" style="min-height: 90vh;">

            <div class="card login-container border-0 shadow-lg">

                <div class="card-body p-4 p-md-5">

                    <h2 class="text-center text-dark mb-4 fw-bold">
                        Đăng nhập
                    </h2>

                    <form action="/login" method="POST" autocomplete="off">

                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

                        <div class="mb-3">

                            <label for="username" class="form-label text-secondary fw-medium">
                                Tên đăng nhập
                            </label>

                            <input type="text" id="username" name="username"
                                class="form-control form-control-brand px-3 py-2" placeholder="Nhập tên đăng nhập..."
                                autocomplete="username" required>

                        </div>

                        <div class="mb-4">

                            <label for="password" class="form-label text-secondary fw-medium">
                                Mật khẩu
                            </label>

                            <input type="password" id="password" name="password"
                                class="form-control form-control-brand px-3 py-2" placeholder="Nhập mật khẩu..."
                                autocomplete="current-password" required>

                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3">

                            <a href="/khachHangTaoTaiKhoan" class="text-decoration-none">
                                Tạo tài khoản
                            </a>

                        </div>

                        <div class="d-grid">

                            <button type="submit" class="btn btn-primary btn-lg">

                                <i class="fa-solid fa-right-to-bracket"></i>

                                Đăng nhập

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

        <script>
            const serverMessage = JSON.parse(
                '<%- JSON.stringify(typeof msg !== "undefined" ? msg : "") %>'
            );

            const messageType = JSON.parse(
                '<%- JSON.stringify(typeof type !== "undefined" ? type : "") %>'
            );

            if (
                typeof serverMessage === 'string' &&
                serverMessage.trim() !== ''
            ) {
                const isError = messageType === 'error';

                Swal.fire({
                    icon: isError ? 'error' : 'success',
                    title: isError
                        ? 'Đăng nhập thất bại'
                        : 'Thành công',
                    text: serverMessage,
                    confirmButtonColor: '#667eea',
                    confirmButtonText: 'OK'
                });
            }
        </script>

</body>

</html>