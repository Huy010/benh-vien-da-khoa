<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Thông tin cá nhân</title>

  <link rel="stylesheet" href="/css/khachHang/home.css" />

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
    crossorigin="anonymous" />

  <style>
    .profile-container {
      margin-top: 100px;
      margin-bottom: 50px;
    }

    .card-profile {
      border: none;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }

    .form-label {
      font-weight: 600;
      color: #495057;
    }
  </style>
</head>

<body>
  <main class="main">

    <%- include('../header') %>

      <div class="content profile-container">
        <div class="container">
          <div class="row justify-content-center">

            <div class="col-lg-9">

              <div class="d-flex align-items-center mb-4">
                <h2 class="text-primary fw-bold mb-0">
                  <i class="fa-solid fa-user-pen me-2"></i>
                  Cập nhật thông tin cá nhân
                </h2>
              </div>

              <div class="card card-profile">
                <div class="card-body p-4 p-md-5">

                  <form action="/capNhatThongTin" method="POST">

                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

                    <h5 class="text-muted mb-4 border-bottom pb-2">
                      Thông tin tài khoản
                    </h5>

                    <div class="row mb-3">

                      <div class="col-md-6">
                        <label for="hoTen" class="form-label">
                          Họ và tên
                          <span class="text-danger">*</span>
                        </label>

                        <input type="text" class="form-control" id="hoTen" name="hoTen"
                          value="<%= typeof profile !== 'undefined' && profile.hoTen ? profile.hoTen : '' %>"
                          required />
                      </div>

                      <div class="col-md-6 mt-3 mt-md-0">
                        <label for="soDienThoai" class="form-label">
                          Số điện thoại
                          <span class="text-danger">*</span>
                        </label>

                        <input type="text" class="form-control" id="soDienThoai" name="soDienThoai"
                          value="<%= typeof profile !== 'undefined' && profile.soDienThoai ? profile.soDienThoai : '' %>"
                          pattern="^0[35789][0-9]{8}$"
                          title="Vui lòng nhập số điện thoại Việt Nam hợp lệ, ví dụ: 0987654321" required />
                      </div>

                    </div>

                    <div class="row mb-4">

                      <div class="col-md-12">
                        <label for="email" class="form-label">
                          Email
                        </label>

                        <input type="email" class="form-control" id="email" name="email"
                          value="<%= typeof profile !== 'undefined' && profile.email ? profile.email : '' %>" />
                      </div>

                    </div>

                    <h5 class="text-muted mb-4 border-bottom pb-2 mt-5">
                      Thông tin y tế
                    </h5>

                    <div class="row mb-3">

                      <div class="col-md-4">
                        <label for="ngaySinh" class="form-label">
                          Ngày sinh
                        </label>

                        <input type="date" class="form-control" id="ngaySinh" name="ngaySinh"
                          value="<%= typeof profile !== 'undefined' && profile.ngaySinh ? profile.ngaySinh : '' %>" />

                        <div class="form-text">
                          Nhấn vào biểu tượng lịch để chọn ngày sinh.
                        </div>
                      </div>

                      <div class="col-md-4 mt-3 mt-md-0">
                        <label for="gioiTinh" class="form-label">
                          Giới tính
                        </label>

                        <select class="form-select" id="gioiTinh" name="gioiTinh">

                          <option value="" <%=typeof profile==='undefined' || !profile.gioiTinh ? 'selected' : '' %>>
                            Chọn giới tính
                          </option>

                          <option value="Nam" <%=typeof profile !=='undefined' && profile.gioiTinh==='Nam' ? 'selected'
                            : '' %>>
                            Nam
                          </option>

                          <option value="Nu" <%=typeof profile !=='undefined' && profile.gioiTinh==='Nu' ? 'selected'
                            : '' %>>
                            Nữ
                          </option>

                          <option value="Khac" <%=typeof profile !=='undefined' && profile.gioiTinh==='Khac'
                            ? 'selected' : '' %>>
                            Khác
                          </option>

                        </select>
                      </div>

                      <div class="col-md-4 mt-3 mt-md-0">
                        <label for="nhomMau" class="form-label">
                          Nhóm máu
                        </label>

                        <select class="form-select" id="nhomMau" name="nhomMau">

                          <option value="" <%=typeof profile==='undefined' || !profile.nhomMau ? 'selected' : '' %>>
                            Chưa rõ
                          </option>

                          <option value="A" <%=typeof profile !=='undefined' && profile.nhomMau==='A' ? 'selected' : ''
                            %>>
                            A
                          </option>

                          <option value="B" <%=typeof profile !=='undefined' && profile.nhomMau==='B' ? 'selected' : ''
                            %>>
                            B
                          </option>

                          <option value="AB" <%=typeof profile !=='undefined' && profile.nhomMau==='AB' ? 'selected'
                            : '' %>>
                            AB
                          </option>

                          <option value="O" <%=typeof profile !=='undefined' && profile.nhomMau==='O' ? 'selected' : ''
                            %>>
                            O
                          </option>

                        </select>
                      </div>

                    </div>

                    <div class="row mb-3">

                      <div class="col-md-12">
                        <label for="diaChi" class="form-label">
                          Địa chỉ liên hệ
                        </label>

                        <input type="text" class="form-control" id="diaChi" name="diaChi"
                          value="<%= typeof profile !== 'undefined' && profile.diaChi ? profile.diaChi : '' %>"
                          placeholder="Ví dụ: Ninh Kiều, Cần Thơ..." />
                      </div>

                    </div>

                    <div class="row mb-4">

                      <div class="col-md-12">
                        <label for="tienSuBenhLy" class="form-label">
                          Tiền sử bệnh lý nếu có
                        </label>

                        <textarea class="form-control" id="tienSuBenhLy" name="tienSuBenhLy" rows="3"
                          placeholder="Ghi chú về các bệnh lý nền, dị ứng thuốc..."><%= typeof profile !== 'undefined' && profile.tienSuBenhLy ? profile.tienSuBenhLy : '' %></textarea>
                      </div>

                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-4">

                      <button type="submit" class="btn btn-primary">

                        <i class="fa-solid fa-floppy-disk"></i>
                        Lưu thay đổi

                      </button>

                    </div>

                  </form>

                </div>
              </div>

            </div>

          </div>
        </div>
      </div>

      <%- include('../footer') %>

  </main>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <div id="alert-data" data-status="<%= typeof status !== 'undefined' ? status : '' %>"
    data-msg="<%= typeof msg !== 'undefined' ? msg : '' %>">
  </div>

  <script>
    const alertData = document.getElementById('alert-data');

    const statusMessage = alertData.dataset.status;
    const alertMessage = alertData.dataset.msg;

    if (statusMessage && alertMessage) {
      Swal.fire({
        icon: statusMessage,
        title: statusMessage === 'success'
          ? 'Thành công'
          : 'Thông báo lỗi',
        text: alertMessage,
        confirmButtonText: 'Đồng ý'
      });
    }
  </script>

  <script>
    const ngaySinhInput = document.getElementById('ngaySinh');

    if (ngaySinhInput) {
      const homQua = new Date();

      homQua.setDate(homQua.getDate() - 1);

      const nam = homQua.getFullYear();
      const thang = String(homQua.getMonth() + 1).padStart(2, '0');
      const ngay = String(homQua.getDate()).padStart(2, '0');

      ngaySinhInput.max = `${nam}-${thang}-${ngay}`;
    }
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous">
  </script>

</body>

</html>