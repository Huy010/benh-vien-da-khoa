<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thông tin cá nhân</title>
    
    <link rel="stylesheet" href="/css/khachHang/home.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous"/>
    
    <style>
      .profile-container {
        margin-top: 100px; /* Tránh bị che bởi header fixed */
        margin-bottom: 50px;
      }
      .card-profile {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
      }
      .form-label {
        font-weight: 600;
        color: #495057;
      }
    </style>
  </head>
  <body>
    <main class="main">
      <%- include('../header') %>

      <div class="content profile-container">
        <div class="container">
          <div class="row justify-content-center">
            <div class="col-lg-9">
              
              <div class="d-flex align-items-center mb-4">
                <h2 class="text-primary fw-bold mb-0">
                  <i class="fa-solid fa-user-pen me-2"></i> Cập nhật thông tin cá nhân
                </h2>
              </div>

              <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                  <i class="fa-solid fa-circle-check me-2"></i> <%= success_msg %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              <% } %>
              
              <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                  <i class="fa-solid fa-circle-exclamation me-2"></i> <%= error_msg %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              <% } %>

              <div class="card card-profile">
                <div class="card-body p-4 p-md-5">
                  <form action="/capNhatThongTin" method="POST">
                    
                    <h5 class="text-muted mb-4 border-bottom pb-2">Thông tin tài khoản (Từ bảng NguoiDung)</h5>
                    
                    <div class="row mb-3">
                      <div class="col-md-6">
                        <label for="hoTen" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="hoTen" name="hoTen" 
                               value="<%= typeof user !== 'undefined' ? user.hoTen : '' %>" required>
                      </div>
                      <div class="col-md-6 mt-3 mt-md-0">
                        <label for="soDienThoai" class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="soDienThoai" name="soDienThoai" 
                               value="<%= typeof user !== 'undefined' ? user.soDienThoai : '' %>" pattern="[0-9]{10}" title="Vui lòng nhập số điện thoại 10 số" required>
                      </div>
                    </div>

                    <div class="row mb-4">
                      <div class="col-md-12">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" name="email" 
                               value="<%= typeof user !== 'undefined' ? user.email : '' %>">
                      </div>
                    </div>

                    <h5 class="text-muted mb-4 border-bottom pb-2 mt-5">Thông tin y tế (Từ bảng KhachHang)</h5>

                    <div class="row mb-3">
                      <div class="col-md-4">
                        <label for="ngaySinh" class="form-label">Ngày sinh</label>
                        <input type="date" class="form-control" id="ngaySinh" name="ngaySinh" 
                               value="<%= typeof user !== 'undefined' && user.ngaySinh ? user.ngaySinh : '' %>">
                      </div>
                      <div class="col-md-4 mt-3 mt-md-0">
                        <label for="gioiTinh" class="form-label">Giới tính</label>
                        <select class="form-select" id="gioiTinh" name="gioiTinh">
                          <option value="" disabled <%= !user.gioiTinh ? 'selected' : '' %>>Chọn giới tính</option>
                          <option value="Nam" <%= typeof user !== 'undefined' && user.gioiTinh === 'Nam' ? 'selected' : '' %>>Nam</option>
                          <option value="Nu" <%= typeof user !== 'undefined' && user.gioiTinh === 'Nu' ? 'selected' : '' %>>Nữ</option>
                          <option value="Khac" <%= typeof user !== 'undefined' && user.gioiTinh === 'Khac' ? 'selected' : '' %>>Khác</option>
                        </select>
                      </div>
                      <div class="col-md-4 mt-3 mt-md-0">
                        <label for="nhomMau" class="form-label">Nhóm máu</label>
                        <select class="form-select" id="nhomMau" name="nhomMau">
                          <option value="" <%= !user.nhomMau ? 'selected' : '' %>>Chưa rõ</option>
                          <option value="A" <%= typeof user !== 'undefined' && user.nhomMau === 'A' ? 'selected' : '' %>>A</option>
                          <option value="B" <%= typeof user !== 'undefined' && user.nhomMau === 'B' ? 'selected' : '' %>>B</option>
                          <option value="AB" <%= typeof user !== 'undefined' && user.nhomMau === 'AB' ? 'selected' : '' %>>AB</option>
                          <option value="O" <%= typeof user !== 'undefined' && user.nhomMau === 'O' ? 'selected' : '' %>>O</option>
                        </select>
                      </div>
                    </div>

                    <div class="row mb-3">
                      <div class="col-md-12">
                        <label for="diaChi" class="form-label">Địa chỉ liên hệ</label>
                        <input type="text" class="form-control" id="diaChi" name="diaChi" 
                               value="<%= typeof user !== 'undefined' ? user.diaChi : '' %>" placeholder="Ví dụ: Ninh Kiều, Cần Thơ...">
                      </div>
                    </div>

                    <div class="row mb-4">
                      <div class="col-md-12">
                        <label for="tienSuBenhLy" class="form-label">Tiền sử bệnh lý (Nếu có)</label>
                        <textarea class="form-control" id="tienSuBenhLy" name="tienSuBenhLy" rows="3" 
                                  placeholder="Ghi chú về các bệnh lý nền, dị ứng thuốc..."><%= typeof user !== 'undefined' ? user.tienSuBenhLy : '' %></textarea>
                      </div>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-4">
                      <button type="reset" class="btn btn-light border"><i class="fa-solid fa-rotate-left"></i> Khôi phục</button>
                      <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi</button>
                    </div>

                  </form>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>

      <%- include('../footer') %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  </body>a
</html>