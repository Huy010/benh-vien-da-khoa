<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Tạo tài khoản</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/khachHang/login.css">
    <link rel="stylesheet" href="/css/khachHang/home.css">

    <!-- Bootstrap -->
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
</head>

<body>

    <%- include('../header') %>

        <div class="wrapper">

            <div class="login-card wrapper__taoTaiKhoan" style="max-width:1000px">

                <h4 class="mb-4 fw-bold text-primary">
                    + Thêm Người Dùng Mới
                </h4>

                <p class="text-muted mb-4">
                    Nhập thông tin chi tiết để tạo tài khoản mới vào hệ thống
                </p>

                <form action="/khachhangtaotaikhoan" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div class="row g-4">

                        <!-- ===== CỘT TRÁI ===== -->
                        <div class="col-md-6">

                            <h6 class="fw-bold text-uppercase mb-3">
                                Thông tin tài khoản
                            </h6>

                            <div class="mb-3">
                                <label class="form-label">Tên đăng nhập *</label>
                                <input type="text" name="username" class="form-control" autocomplete="off" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Mật khẩu *</label>
                                <input type="password" name="password" class="form-control" autocomplete="new-password"
                                    required>
                            </div>
                        </div>


                        <!-- ===== CỘT PHẢI ===== -->
                        <div class="col-md-6">

                            <h6 class="fw-bold text-uppercase mb-3">
                                Thông tin cá nhân
                            </h6>

                            <div class="mb-3">
                                <label class="form-label">Họ và tên *</label>
                                <input type="text" name="hoTen" class="form-control" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email *</label>
                                <input type="email" name="email" class="form-control" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Số điện thoại *</label>
                                <input type="text" name="soDienThoai" class="form-control" required
                                    pattern="[0-9]{10}" title="Số điện thoại phải 10 số"
                                    maxlength="10">
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Ngày sinh</label>
                                    <input type="date" name="ngaySinh" class="form-control" required>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Giới tính</label>
                                    <select name="gioiTinh" class="form-select">
                                        <option value="Nam">Nam</option>
                                        <option value="Nu">Nữ</option>
                                        <option value="Khac">Khác</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Địa chỉ</label>
                                <input type="text" name="diaChi" class="form-control">
                            </div>

                        </div>

                    </div>


                    <!-- ===== BUTTONS ===== -->
                    <div class="d-flex justify-content-end gap-3 mt-4">

                        <a href="/login" class="btn btn-secondary">
                            Quay lại
                        </a>

                        <button type="submit" class="btn btn-primary">
                            Lưu Người Dùng
                        </button>

                    </div>

                </form>

            </div>

        </div>


        <% if (typeof msg !=='undefined' && msg) { %>
            <script nonce="<%= cspNonce %>">
                Swal.fire({
                    icon: 'error',
                    title: 'Thông báo',
                    text: '<%= msg %>'
                })
            </script>
            <% } %>

</body>

</html>