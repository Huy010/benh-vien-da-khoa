<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lịch Trực Của Tôi</title>

    <link rel="stylesheet" href="/css/bacSi/sidebar.css">
    <link rel="stylesheet" href="/css/bacSi/style.css">
    <link rel="stylesheet" href="/css/bacSi/xemLich.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        /* ép 7 cột luôn nằm 1 hàng trên màn hình lớn */
        .row-cols-7 > * {
            flex: 0 0 calc(100% / 7);
            max-width: calc(100% / 7);
        }

        /* responsive mobile: chia 2 cột cho dễ nhìn với số lượng ngày lớn */
        @media (max-width: 768px) {
            .row-cols-7 > * {
                flex: 0 0 calc(100% / 2);
                max-width: calc(100% / 2);
            }
        }
    </style>
</head>

<body>

    <%- include('sidebar', { page: page }) %>

    <div class="main-content">
        
        <div class="mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h3 class="page-title mb-1">Quản Lý Lịch Khám</h3>
                <p class="text-muted ms-3 mb-0">Theo dõi lịch trực và danh sách bệnh nhân theo tháng.</p>
            </div>
            
            <button class="btn btn-warning fw-bold text-dark shadow-sm px-4" onclick="moPopupDoiLich()">
                <i class="fa-solid fa-calendar-plus"></i> Đăng ký đổi lịch
            </button>
        </div>

        <div class="week-navigation mb-4 d-flex flex-wrap gap-3 align-items-center justify-content-between">

            <a href="/bacsi/xemLich?date=<%= prevMonthStr %>" class="btn btn-outline-primary">
                <i class="fa-solid fa-chevron-left"></i> Tháng trước
            </a>

            <div class="d-flex flex-column align-items-center gap-2">
                <h4 class="fw-bold mb-0 text-dark text-center">
                    <%= currentMonthDisplay %>
                </h4>

                <form id="goToMonthForm" action="/bacsi/xemLich" method="GET">
                    <div class="input-group input-group-sm" style="max-width: 200px;">
                        <input 
                            type="month" 
                            name="date" 
                            id="monthInput"
                            class="form-control text-center fw-bold text-primary" 
                            value="<%= currentMonthInput %>"
                            onchange="document.getElementById('goToMonthForm').submit();"
                            onclick="this.showPicker();" 
                            style="cursor: pointer; caret-color: transparent;"
                        >
                    </div>
                </form>
            </div>

            <a href="/bacsi/xemLich?date=<%= nextMonthStr %>" class="btn btn-outline-primary">
                Tháng sau <i class="fa-solid fa-chevron-right"></i>
            </a>

        </div>

        <div class="row row-cols-7 g-3 mb-2 text-center fw-bold text-secondary d-none d-md-flex">
            <div class="col">Thứ 2</div>
            <div class="col">Thứ 3</div>
            <div class="col">Thứ 4</div>
            <div class="col">Thứ 5</div>
            <div class="col">Thứ 6</div>
            <div class="col">Thứ 7</div>
            <div class="col text-danger">Chủ nhật</div>
        </div>

        <div class="row row-cols-7 g-3">
            <% monthDays.forEach(day => { %>
                <div class="col <%= day.isEmpty ? 'd-none d-md-block' : '' %>">
                    
                    <% if (day.isEmpty) { %>
                        <div class="day-card" style="background: transparent; border: none; box-shadow: none;"></div>
                    <% } else { %>
                        
                        <div class="day-card <%= day.hasLich ? 'active-day' : '' %>">
                            <div class="day-title d-md-none"><%= day.dayName %></div>
                            
                            <div class="day-date"><%= day.displayDayOnly %></div>
                            
                            <% if (day.hasLich) { %>
                                <div class="room-badge mt-2">
                                    P. <%= day.soPhong %>
                                </div>
                            <% } else { %>
                                <div class="no-duty mt-2">
                                    <p class="mb-0">Không trực</p>
                                </div>
                            <% } %>
                        </div>
                        
                    <% } %>
                    
                </div>
            <% }) %>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/botstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function moPopupDoiLich() {
            // 1. Hiện loading và gọi API lấy data
            Swal.fire({ title: 'Đang tải dữ liệu...', didOpen: () => { Swal.showLoading(); } });

            try {
                const response = await fetch('/bacsi/thongTinDoiLich');
                const data = await response.json();

                if (!data.success) throw new Error();

                // 2. Kiểm tra nếu không có lịch trực tương lai
                if (data.lichTruc.length === 0) {
                    return Swal.fire('Thông báo', 'Bạn không có lịch trực nào trong tương lai để đổi.', 'info');
                }
                if (data.bacSiCungKhoa.length === 0) {
                    return Swal.fire('Thông báo', 'Khoa của bạn hiện không có bác sĩ nào khác để đổi lịch.', 'info');
                }

                // 3. Tạo HTML cho các thẻ Select
                let optionLich = data.lichTruc.map(l => `<option value="${l.ngayStr}">${l.ngayDisplay}</option>`).join('');
                let optionBacSi = data.bacSiCungKhoa.map(bs => `<option value="${bs.id}">${bs.hoTen}</option>`).join('');

                const htmlForm = `
                    <div class="text-start">
                        <div class="mb-3">
                            <label class="fw-bold text-muted small">Tên bác sĩ xin đổi:</label>
                            <input type="text" class="form-control bg-light" value="${data.tenBacSi}" readonly disabled>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold text-dark small">Ngày muốn đổi lịch:</label>
                            <select id="swal-ngay-doi" class="form-select border-primary cursor-pointer">
                                <option value="" disabled selected>-- Chọn ngày bạn có lịch --</option>
                                ${optionLich}
                            </select>
                        </div>
                        <div class="mb-2">
                            <label class="fw-bold text-dark small">Bác sĩ thay thế (cùng khoa):</label>
                            <select id="swal-bs-thay-the" class="form-select border-primary cursor-pointer">
                                <option value="" disabled selected>-- Chọn người thay thế --</option>
                                ${optionBacSi}
                            </select>
                        </div>
                    </div>
                `;

                // 4. Hiển thị Popup xịn xò
                const { value: formValues } = await Swal.fire({
                    title: 'Đăng ký đổi lịch',
                    html: htmlForm,
                    focusConfirm: false,
                    showCancelButton: true,
                    confirmButtonText: 'Tiếp tục <i class="fa-solid fa-arrow-right"></i>',
                    cancelButtonText: 'Hủy',
                    preConfirm: () => {
                        const ngay = document.getElementById('swal-ngay-doi').value;
                        const idBs = document.getElementById('swal-bs-thay-the').value;
                        const tenBsThayThe = document.getElementById('swal-bs-thay-the').options[document.getElementById('swal-bs-thay-the').selectedIndex]?.text;
                        const ngayDisplay = document.getElementById('swal-ngay-doi').options[document.getElementById('swal-ngay-doi').selectedIndex]?.text;

                        if (!ngay || !idBs) {
                            Swal.showValidationMessage('Vui lòng chọn ngày và bác sĩ thay thế!');
                            return false;
                        }
                        return { ngay, idBs, ngayDisplay, tenBsThayThe };
                    }
                });

                // 5. Nếu điền đủ form và bấm Tiếp tục
                if (formValues) {
                    Swal.fire({
                        title: 'Xác nhận yêu cầu',
                        html: `Bạn muốn xin đổi lịch trực ngày <b>${formValues.ngayDisplay}</b> <br>Người thay thế: <b>Bs. ${formValues.tenBsThayThe}</b>?`,
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonColor: '#3085d6',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Đồng ý gửi',
                        cancelButtonText: 'Hủy'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            guiYeuCauDoiLich(formValues.ngay, formValues.idBs);
                        }
                    });
                }

            } catch (error) {
                Swal.fire('Lỗi!', 'Không thể lấy dữ liệu, vui lòng thử lại sau.', 'error');
            }
        }

        // Hàm gọi API gửi về backend (đã cập nhật)
        function guiYeuCauDoiLich(ngay, idBsThayThe) {
            Swal.fire({ title: 'Đang gửi yêu cầu...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

            fetch('/bacsi/yeuCauDoiLich', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ngayMuonDoi: ngay, id_bacSiThanhThe: idBsThayThe })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    Swal.fire('Thành công!', 'Yêu cầu đổi lịch của bạn đã được gửi cho Quản lý.', 'success');
                } else {
                    Swal.fire('Lỗi!', data.message, 'error');
                }
            });
        }
        // Hàm gọi API gửi về backend
        function guiYeuCauDoiLich(ngay, idBsThayThe) {
            Swal.fire({ 
                title: 'Đang gửi yêu cầu...', 
                allowOutsideClick: false, 
                didOpen: () => { Swal.showLoading(); } 
            });

            fetch('/bacsi/yeuCauDoiLich', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ngayMuonDoi: ngay, id_bacSiThanhThe: idBsThayThe })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    Swal.fire('Thành công!', 'Yêu cầu đổi lịch của bạn đã được gửi cho Quản lý.', 'success');
                } else {
                    Swal.fire('Lỗi!', data.message, 'error');
                }
            })
            .catch(err => {
                // THÊM ĐOẠN NÀY ĐỂ TRÁNH BỊ TREO POPUP
                console.error(err);
                Swal.fire('Lỗi mạng!', 'Không thể kết nối đến máy chủ. Vui lòng thử lại sau.', 'error');
            });
        }
    </script>
</body>
</html>